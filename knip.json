{
  "$schema": "https://unpkg.com/knip@latest/schema.json",

  "ignore": ["**/__tests__/**", "**/__tests_dts__/**", "**/*.d.ts"],

  "ignoreExportsUsedInFile": true,

  "ignoreDependencies": ["core-js", "regenerator-runtime", "systemjs"],

  "ignoreWorkspaces": ["playground/**", "docs"],

  "workspaces": {
    "packages/vite": {
      "entry": [
        "src/node/index.ts",
        "src/node/cli.ts",
        "src/node/internalIndex.ts",
        "src/client/client.ts",
        "src/client/env.ts",
        "src/module-runner/index.ts"
      ],
      "project": "src/**/*.ts",
      "ignoreDependencies": ["@babel/parser", "rolldown-plugin-dts"]
    },
    "packages/plugin-legacy": {
      "project": "src/**/*.ts"
    },
    "packages/create-vite": {
      "project": "src/**/*.ts"
    }
  }
}
