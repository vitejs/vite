{
  "include": ["tsdown.config.ts", "src"],
  "exclude": ["**/*.spec.ts"],
  "compilerOptions": {
    "outDir": "dist",
    "target": "es2023",
    "module": "preserve",
    "types": ["node"],
    "moduleResolution": "bundler",
    "isolatedDeclarations": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "noUnusedLocals": true
  }
}
