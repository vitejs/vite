{
  "include": ["tsdown.config.ts", "src", "__tests__"],
  "compilerOptions": {
    "rootDir": "..", // imports 'packages/vite/rollupLicensePlugin.ts'
    "outDir": "dist",
    "target": "es2023",
    "module": "preserve",
    "types": [],
    "noEmit": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "noUnusedLocals": true
  }
}
